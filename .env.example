# tender-scraper — конфігурація
# Скопіюй цей файл: cp .env.example .env
# Заповни обов'язкові змінні — решта опціональна

# ── Обов'язково ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # токен від @BotFather
TELEGRAM_USER_ID=           # твій Telegram chat_id (отримати через @userinfobot)

# ── Якщо є другий бот для клієнта (опціонально) ──────────────────────────────
# TENDER_DIGEST_HUB_ENV=/шлях/до/.env  # шлях до .env іншого бота з TELEGRAM_BOT_TOKEN + ALLOWED_USER_IDS

# ── AI аналіз (опціонально, Level 2 і 3) ─────────────────────────────────────
# З будь-яким з цих ключів tender_digest.py додає «💡 чому релевантно» в Telegram
# і генерує outreach-чернетки німецькою в output/tender_outreach_*.md
# ANTHROPIC_API_KEY=         # Claude API (пріоритетний провайдер)
# TENDER_AI_MODEL=claude-haiku-4-5   # модель Claude (default: claude-haiku-4-5)
# OPENAI_API_KEY=            # OpenAI GPT — fallback якщо нема Claude-ключа
# OPENAI_MODEL=gpt-5.4-mini  # модель OpenAI (default: gpt-5.4-mini)
